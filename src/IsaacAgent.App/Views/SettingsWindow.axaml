<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IsaacAgent.App.ViewModels"
        x:Class="IsaacAgent.App.Views.SettingsWindow"
        Title="Settings"
        Width="500" Height="400"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        x:DataType="vm:SettingsViewModel">

    <Grid RowDefinitions="*,Auto" Margin="20">

        <ScrollViewer Grid.Row="0">
            <StackPanel Spacing="12">

                <TextBlock Text="LLM Provider" FontWeight="SemiBold" />
                <ComboBox SelectedItem="{Binding SelectedProviderType}"
                          ItemsSource="{Binding ProviderTypes}" />

                <TextBlock Text="Endpoint" FontWeight="SemiBold" />
                <TextBox Text="{Binding Endpoint}" Watermark="https://api.example.com/v1" />

                <TextBlock Text="Model" FontWeight="SemiBold" />
                <TextBox Text="{Binding Model}" Watermark="model-name" />

                <TextBlock Text="API Key" FontWeight="SemiBold" />
                <TextBox Text="{Binding ApiKey}" Watermark="sk-..." PasswordChar="*" />

                <TextBlock Text="Note: Changes require restarting the application to take effect."
                           FontSize="11" Opacity="0.5" TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="Cancel" Click="OnCancel" Width="80" />
            <Button Content="Save" Click="OnSave" Width="80" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
