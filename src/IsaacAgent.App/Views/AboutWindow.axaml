<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="IsaacAgent.App.Views.AboutWindow"
        Title="{DynamicResource AboutTitle}"
        Width="400" Height="250"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="{DynamicResource AboutAppName}" FontSize="24" FontWeight="Bold" />
        <TextBlock Text="{DynamicResource AboutDescription}"
                   TextWrapping="Wrap" />
        <TextBlock Text="{Binding VersionText}" Opacity="0.6" />
        <TextBlock Text="{DynamicResource AboutBuiltWith}" Opacity="0.6" />
        <TextBlock Text="{DynamicResource AboutTechStack}"
                   FontSize="11" Opacity="0.4" Margin="0,10,0,0" />
    </StackPanel>
</Window>
