<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="IsaacAgent.App.Views.AboutWindow"
        Title="About IsaacAgent"
        Width="400" Height="250"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="IsaacAgent" FontSize="24" FontWeight="Bold" />
        <TextBlock Text="AI Coding Agent for Binding of Isaac: Repentance Modding"
                   TextWrapping="Wrap" />
        <TextBlock Text="{Binding VersionText}" Opacity="0.6" />
        <TextBlock Text="Built with Avalonia + .NET 8" Opacity="0.6" />
        <TextBlock Text=".NET 8 + Avalonia 11 + CommunityToolkit.Mvvm"
                   FontSize="11" Opacity="0.4" Margin="0,10,0,0" />
    </StackPanel>
</Window>
