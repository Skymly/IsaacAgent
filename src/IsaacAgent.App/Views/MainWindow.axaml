<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IsaacAgent.App.ViewModels"
        xmlns:md="using:IsaacAgent.App.Markdown"
        x:Class="IsaacAgent.App.Views.MainWindow"
        Title="IsaacAgent - Binding of Isaac Modding Assistant"
        Width="1200" Height="800"
        WindowState="Maximized"
        x:DataType="vm:MainViewModel">

    <Grid RowDefinitions="Auto,*,Auto">

        <Menu Grid.Row="0" Background="{DynamicResource SystemControlBackgroundAltMediumBrush}">
            <MenuItem Header="File">
                <MenuItem Header="New Project..." Command="{Binding NewProjectAsyncCommand}" />
                <MenuItem Header="Open Project..." Command="{Binding OpenProjectAsyncCommand}" />
                <Separator />
                <MenuItem Header="Settings..." Click="OnSettings" />
                <Separator />
                <MenuItem Header="Exit" Click="OnExit" />
            </MenuItem>
            <MenuItem Header="Chat">
                <MenuItem Header="Clear Chat" Command="{Binding ClearChatCommand}" />
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="About IsaacAgent" Click="OnAbout" />
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1" ColumnDefinitions="250,*,300">

            <Border Grid.Column="0" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Project Files"
                               FontWeight="Bold" Margin="10,8" />
                    <TextBlock DockPanel.Dock="Top" Text="{Binding Project.ProjectName}"
                               Opacity="0.6" Margin="10,0" />

                    <Border DockPanel.Dock="Bottom" 
                            IsVisible="{Binding Project.HasFilePreview}"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="0,1,0,0"
                            MaxHeight="300">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" 
                                       Text="{Binding Project.FilePreviewName}"
                                       FontFamily="Consolas" FontSize="11"
                                       Opacity="0.7" Margin="10,6,10,4" />
                            <ScrollViewer>
                                <TextBox Text="{Binding Project.FilePreviewContent}"
                                         IsReadOnly="True"
                                         FontFamily="Cascadia Code,Consolas,monospace"
                                         FontSize="12"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         Margin="6,0,6,6" />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <ListBox ItemsSource="{Binding Project.Files}"
                             Margin="0,8,0,0"
                             Background="Transparent"
                             DoubleTapped="OnFileDoubleTapped">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:FileTreeItem">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="Lua" Foreground="#569CD6"
                                               IsVisible="{Binding IsLua}"
                                               FontSize="10" VerticalAlignment="Center" />
                                    <TextBlock Text="XML" Foreground="#CE9178"
                                               IsVisible="{Binding IsXml}"
                                               FontSize="10" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Padding="8">
                <DockPanel>
                    <!-- Tab bar -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                        <Button DockPanel.Dock="Right" Content="+" Padding="8,2"
                                Command="{Binding Chat.AddTabCommand}"
                                FontSize="14" Margin="4,0,0,0" />
                        <ItemsControl ItemsSource="{Binding Chat.Tabs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ChatTabViewModel">
                                    <Panel>
                                        <!-- Active tab: highlighted with accent border -->
                                        <Border Padding="8,4" CornerRadius="4,4,0,0"
                                                BorderBrush="#569CD6" BorderThickness="0,0,0,2"
                                                IsVisible="{Binding IsActive}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <Button Background="Transparent" BorderThickness="0" Padding="0"
                                                        Command="{Binding $parent[ItemsControl].((vm:MainViewModel)Chat).SelectTabCommand}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="Bold" />
                                                </Button>
                                                <Button Background="Transparent" BorderThickness="0" Padding="0"
                                                        Command="{Binding $parent[ItemsControl].((vm:MainViewModel)Chat).CloseTabCommand}"
                                                        CommandParameter="{Binding}"
                                                        FontSize="10" Opacity="0.5" Content="✕"
                                                        IsVisible="{Binding $parent[ItemsControl].((vm:MainViewModel)Chat).CanCloseTabs}" />
                                            </StackPanel>
                                        </Border>
                                        <!-- Inactive tab: dimmed -->
                                        <Border Padding="8,4" CornerRadius="4,4,0,0"
                                                Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                                                IsVisible="{Binding !IsActive}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <Button Background="Transparent" BorderThickness="0" Padding="0"
                                                        Command="{Binding $parent[ItemsControl].((vm:MainViewModel)Chat).SelectTabCommand}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="{Binding Title}" FontSize="12" Opacity="0.6" />
                                                </Button>
                                                <Button Background="Transparent" BorderThickness="0" Padding="0"
                                                        Command="{Binding $parent[ItemsControl].((vm:MainViewModel)Chat).CloseTabCommand}"
                                                        CommandParameter="{Binding}"
                                                        FontSize="10" Opacity="0.5" Content="✕"
                                                        IsVisible="{Binding $parent[ItemsControl].((vm:MainViewModel)Chat).CanCloseTabs}" />
                                            </StackPanel>
                                        </Border>
                                    </Panel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>

                    <!-- Chat content for active tab -->
                    <ScrollViewer x:Name="ChatScrollViewer" DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto"
                                  IsVisible="{Binding Chat.ActiveTab, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <ItemsControl ItemsSource="{Binding Chat.ActiveTab.Messages}" Padding="8">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="8" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ChatMessageViewModel">
                                    <Border CornerRadius="8" Padding="12,8"
                                            Background="{Binding BackgroundBrush}"
                                            HorizontalAlignment="{Binding HorizontalAlign}"
                                            MaxWidth="600">
                                        <Grid>
                                            <!-- Tool call/result: collapsible card -->
                                            <StackPanel Spacing="4" IsVisible="{Binding IsTool}">
                                                <Button Command="{Binding $parent[ItemsControl].((vm:MainViewModel)Chat).ActiveTab.ToggleExpandCommand}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent" BorderThickness="0" Padding="0"
                                                        HorizontalAlignment="Left">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{Binding RoleLabel}"
                                                                   FontSize="11" Opacity="0.7"
                                                                   FontFamily="Cascadia Code,Consolas,monospace" />
                                                        <TextBlock Text="▼" FontSize="9" Opacity="0.4"
                                                                   IsVisible="{Binding IsExpanded}" />
                                                        <TextBlock Text="▶" FontSize="9" Opacity="0.4"
                                                                   IsVisible="{Binding !IsExpanded}" />
                                                    </StackPanel>
                                                </Button>
                                                <TextBlock Text="{Binding ToolArgsPreview}"
                                                           FontSize="11" Opacity="0.5"
                                                           FontFamily="Cascadia Code,Consolas,monospace"
                                                           IsVisible="{Binding !IsExpanded}"
                                                           TextWrapping="Wrap" />
                                                <SelectableTextBlock TextWrapping="Wrap"
                                                                     FontFamily="Cascadia Code,Consolas,monospace"
                                                                     FontSize="12"
                                                                     IsVisible="{Binding IsExpanded}"
                                                                     md:MarkdownRenderer.Markdown="{Binding DebouncedMarkdown}" />
                                            </StackPanel>

                                            <!-- Retrieval results: knowledge sources card -->
                                            <StackPanel Spacing="4" IsVisible="{Binding IsRetrieval}">
                                                <TextBlock Text="📚 Knowledge Retrieved"
                                                           FontSize="11" Opacity="0.7"
                                                           FontFamily="Cascadia Code,Consolas,monospace" />
                                                <SelectableTextBlock TextWrapping="Wrap"
                                                                     FontFamily="Cascadia Code,Consolas,monospace"
                                                                     FontSize="11"
                                                                     md:MarkdownRenderer.Markdown="{Binding DebouncedMarkdown}" />
                                            </StackPanel>

                                            <!-- Regular message -->
                                            <StackPanel Spacing="4" IsVisible="{Binding IsRegular}">
                                                <TextBlock Text="{Binding RoleLabel}"
                                                           FontSize="11" Opacity="0.5" />
                                                <SelectableTextBlock TextWrapping="Wrap"
                                                                     FontFamily="Cascadia Code,Consolas,monospace"
                                                                     FontSize="13"
                                                                     md:MarkdownRenderer.Markdown="{Binding DebouncedMarkdown}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border DockPanel.Dock="Bottom" Padding="8,4" Margin="0,4,0,0"
                            IsVisible="{Binding Chat.ActiveTab, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBox x:Name="ChatInputBox" Grid.Column="0"
                                     Text="{Binding Chat.ActiveTab.InputText}"
                                     Watermark="Ask about Isaac modding... (Ctrl+Enter to send)"
                                     AcceptsReturn="True"
                                     MinHeight="40"
                                     IsEnabled="{Binding !Chat.ActiveTab.IsGenerating}"
                                     KeyDown="OnInputKeyDown" />
                            <Button Grid.Column="1"
                                    Content="Send"
                                    Command="{Binding Chat.ActiveTab.SendCommand}"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Stretch"
                                    IsEnabled="{Binding !Chat.ActiveTab.IsGenerating}" />
                            <Button Grid.Column="2"
                                    Content="Cancel"
                                    Command="{Binding Chat.ActiveTab.CancelCommand}"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Stretch"
                                    IsVisible="{Binding Chat.ActiveTab.IsGenerating}" />
                        </Grid>
                    </Border>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Quick Reference"
                               FontWeight="Bold" Margin="10,8" />
                    <ScrollViewer>
                        <StackPanel Spacing="4" Margin="10,0">
                            <TextBlock Text="Common Callbacks" FontWeight="SemiBold" Margin="0,8,0,4" />
                            <ItemsControl ItemsSource="{Binding QuickReference.Callbacks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" Opacity="0.7" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Key Classes" FontWeight="SemiBold" Margin="0,12,0,4" />
                            <ItemsControl ItemsSource="{Binding QuickReference.Classes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" Opacity="0.7" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Mod Structure" FontWeight="SemiBold" Margin="0,12,0,4" />
                            <ItemsControl ItemsSource="{Binding QuickReference.ModStructure}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" Opacity="0.7" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource SystemControlBackgroundAltMediumBrush}" Padding="10,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" FontSize="11" Opacity="0.6"
                           FontFamily="Cascadia Code,Consolas,monospace"
                           IsVisible="{Binding Chat.ActiveTab, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="↑{0} ↓{1} tokens">
                            <Binding Path="Chat.ActiveTab.TotalInputTokens" />
                            <Binding Path="Chat.ActiveTab.TotalOutputTokens" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <TextBlock Text="{Binding StatusText}" FontSize="12" Opacity="0.7" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
