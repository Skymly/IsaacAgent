<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IsaacAgent.App.ViewModels"
        xmlns:services="using:IsaacAgent.App.Services"
        xmlns:conv="using:IsaacAgent.App.Converters"
        xmlns:md="using:IsaacAgent.App.Markdown"
        x:Class="IsaacAgent.App.Views.MainWindow"
        Title="{DynamicResource AppTitle}"
        Width="1200" Height="800"
        WindowState="Maximized"
        x:DataType="vm:MainViewModel">

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <Menu Grid.Row="0" Background="{DynamicResource SystemControlBackgroundAltMediumBrush}">
            <MenuItem Header="{DynamicResource MenuFile}">
                <MenuItem Header="{DynamicResource MenuFileNewProject}" Command="{Binding NewProjectAsyncCommand}" />
                <MenuItem Header="{DynamicResource MenuFileNewFromTemplate}" Click="OnTemplateGallery" InputGesture="Ctrl+Shift+T" />
                <MenuItem Header="{DynamicResource MenuFileOpenProject}" Command="{Binding OpenProjectAsyncCommand}" />
                <Separator />
                <MenuItem Header="{DynamicResource MenuFileSettings}" Click="OnSettings" />
                <Separator />
                <MenuItem Header="{DynamicResource MenuFileExit}" Click="OnExit" />
            </MenuItem>
            <MenuItem Header="{DynamicResource MenuChat}">
                <MenuItem Header="{DynamicResource MenuChatClear}" Command="{Binding ClearChatCommand}" />
                <Separator />
                <MenuItem Header="{DynamicResource MenuChatExportMarkdown}" Command="{Binding ExportChatMarkdownCommand}" />
                <MenuItem Header="{DynamicResource MenuChatExportJson}" Command="{Binding ExportChatJsonCommand}" />
            </MenuItem>
            <MenuItem Header="{DynamicResource MenuView}">
                <MenuItem Header="{DynamicResource MenuViewDiffViewer}" Click="OnDiffViewer" InputGesture="Ctrl+Shift+D" />
            </MenuItem>
            <MenuItem Header="{DynamicResource MenuHelp}">
                <MenuItem Header="{DynamicResource MenuHelpCommandPalette}" Click="OnCommandPalette" InputGesture="Ctrl+Shift+P" />
                <Separator />
                <MenuItem Header="{DynamicResource MenuHelpAbout}" Click="OnAbout" />
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1" ColumnDefinitions="250,*,300">

            <Border Grid.Column="0" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource PanelProjectFiles}"
                               FontWeight="Bold" Margin="10,8" />
                    <TextBlock DockPanel.Dock="Top" Text="{Binding Project.ProjectName}"
                               Opacity="0.6" Margin="10,0" />

                    <!-- File search box -->
                    <TextBox DockPanel.Dock="Top"
                             Text="{Binding Project.FileSearchText}"
                             Watermark="{DynamicResource FileSearchWatermark}"
                             Margin="10,4,10,4"
                             InnerLeftContent="🔍"
                             FontSize="12" />

                    <Border DockPanel.Dock="Bottom" 
                            IsVisible="{Binding Project.HasFilePreview}"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="0,1,0,0"
                            MaxHeight="300">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" 
                                       Text="{Binding Project.FilePreviewName}"
                                       FontFamily="Consolas" FontSize="11"
                                       Opacity="0.7" Margin="10,6,10,4" />
                            <ScrollViewer>
                                <TextBox Text="{Binding Project.FilePreviewContent}"
                                         IsReadOnly="True"
                                         FontFamily="Cascadia Code,Consolas,monospace"
                                         FontSize="12"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         Margin="6,0,6,6" />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- File search results (shown when searching) -->
                    <ListBox x:Name="FileSearchResults"
                             ItemsSource="{Binding Project.FilteredFiles}"
                             Margin="0,8,0,0"
                             Background="Transparent"
                             BorderThickness="0"
                             DoubleTapped="OnFileDoubleTapped"
                             IsVisible="{Binding Project.HasFileSearch}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:FileTreeItem">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="Lua" Foreground="{DynamicResource IsaacLuaTagBrush}"
                                               IsVisible="{Binding IsLua}"
                                               FontSize="10" VerticalAlignment="Center" />
                                    <TextBlock Text="XML" Foreground="{DynamicResource IsaacXmlTagBrush}"
                                               IsVisible="{Binding IsXml}"
                                               FontSize="10" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Path}" VerticalAlignment="Center" FontSize="12" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TreeView x:Name="FileTreeView"
                              ItemsSource="{Binding Project.Files}"
                              Margin="0,8,0,0"
                              Background="Transparent"
                              BorderThickness="0"
                              DoubleTapped="OnFileDoubleTapped"
                              IsVisible="{Binding !Project.HasFileSearch}">
                        <TreeView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{DynamicResource FileNewFile}"
                                          Command="{Binding Project.CreateNewFileCommand}"
                                          CommandParameter="{Binding $self}" />
                                <MenuItem Header="{DynamicResource FileNewFolder}"
                                          Command="{Binding Project.CreateNewFolderCommand}"
                                          CommandParameter="{Binding $self}" />
                                <Separator />
                                <MenuItem Header="{DynamicResource FileRename}"
                                          Command="{Binding Project.RenameFileCommand}"
                                          CommandParameter="{Binding $self}" />
                                <MenuItem Header="{DynamicResource FileDelete}"
                                          Command="{Binding Project.DeleteFileCommand}"
                                          CommandParameter="{Binding $self}" />
                                <Separator />
                                <MenuItem Header="{DynamicResource FileCopyPath}"
                                          Command="{Binding Project.CopyPathCommand}"
                                          CommandParameter="{Binding $self}" />
                                <MenuItem Header="{DynamicResource FileOpenInExplorer}"
                                          Command="{Binding Project.OpenInExplorerCommand}"
                                          CommandParameter="{Binding $self}" />
                                <MenuItem Header="{DynamicResource FileOpenExternal}"
                                          Command="{Binding Project.OpenInExternalEditorCommand}"
                                          CommandParameter="{Binding $self}" />
                            </ContextMenu>
                        </TreeView.ContextMenu>
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate x:DataType="vm:FileTreeItem"
                                              ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="📁" FontSize="10"
                                               IsVisible="{Binding IsDirectory}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Lua" Foreground="{DynamicResource IsaacLuaTagBrush}"
                                               IsVisible="{Binding IsLua}"
                                               FontSize="10" VerticalAlignment="Center" />
                                    <TextBlock Text="XML" Foreground="{DynamicResource IsaacXmlTagBrush}"
                                               IsVisible="{Binding IsXml}"
                                               FontSize="10" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Padding="8">
                <DockPanel>
                    <!-- Tab bar -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                        <Button DockPanel.Dock="Right" Content="+" Padding="8,2"
                                Command="{Binding Chat.AddTabCommand}"
                                FontSize="14" Margin="4,0,0,0" />
                        <ItemsControl ItemsSource="{Binding Chat.Tabs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ChatTabViewModel">
                                    <Panel>
                                        <!-- Active tab: highlighted with accent border -->
                                        <Border Padding="8,4" CornerRadius="4,4,0,0"
                                                BorderBrush="{DynamicResource IsaacAccentBrush}" BorderThickness="0,0,0,2"
                                                IsVisible="{Binding IsActive}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <Button Background="Transparent" BorderThickness="0" Padding="0"
                                                        Command="{Binding $parent[ItemsControl].DataContext.Chat.SelectTabCommand}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="Bold" />
                                                </Button>
                                                <Button Background="Transparent" BorderThickness="0" Padding="0"
                                                        Command="{Binding $parent[ItemsControl].DataContext.Chat.CloseTabCommand}"
                                                        CommandParameter="{Binding}"
                                                        FontSize="10" Opacity="0.5" Content="✕"
                                                        IsVisible="{Binding $parent[ItemsControl].DataContext.Chat.CanCloseTabs}" />
                                            </StackPanel>
                                        </Border>
                                        <!-- Inactive tab: dimmed -->
                                        <Border Padding="8,4" CornerRadius="4,4,0,0"
                                                Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                                                IsVisible="{Binding !IsActive}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <Button Background="Transparent" BorderThickness="0" Padding="0"
                                                        Command="{Binding $parent[ItemsControl].DataContext.Chat.SelectTabCommand}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="{Binding Title}" FontSize="12" Opacity="0.6" />
                                                </Button>
                                                <Button Background="Transparent" BorderThickness="0" Padding="0"
                                                        Command="{Binding $parent[ItemsControl].DataContext.Chat.CloseTabCommand}"
                                                        CommandParameter="{Binding}"
                                                        FontSize="10" Opacity="0.5" Content="✕"
                                                        IsVisible="{Binding $parent[ItemsControl].DataContext.Chat.CanCloseTabs}" />
                                            </StackPanel>
                                        </Border>
                                    </Panel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>

                    <!-- Chat content for active tab (virtualized for performance) -->
                    <ScrollViewer x:Name="ChatScrollViewer" DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto"
                                  IsVisible="{Binding Chat.ActiveTab, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <ListBox ItemsSource="{Binding Chat.ActiveTab.Messages}" Padding="8"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ChatMessageViewModel">
                                    <Border CornerRadius="8" Padding="12,8"
                                            Background="{Binding BackgroundBrush}"
                                            HorizontalAlignment="{Binding HorizontalAlign}"
                                            MaxWidth="600">
                                        <Grid>
                                            <!-- Tool call/result: collapsible card -->
                                            <StackPanel Spacing="4" IsVisible="{Binding IsTool}">
                                                <Button Command="{Binding $parent[ListBox].DataContext.Chat.ActiveTab.ToggleExpandCommand}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent" BorderThickness="0" Padding="0"
                                                        HorizontalAlignment="Left">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{Binding RoleLabel}"
                                                                   FontSize="11" Opacity="0.7"
                                                                   FontFamily="Cascadia Code,Consolas,monospace" />
                                                        <TextBlock Text="▼" FontSize="9" Opacity="0.4"
                                                                   IsVisible="{Binding IsExpanded}" />
                                                        <TextBlock Text="▶" FontSize="9" Opacity="0.4"
                                                                   IsVisible="{Binding !IsExpanded}" />
                                                    </StackPanel>
                                                </Button>
                                                <TextBlock Text="{Binding ToolArgsPreview}"
                                                           FontSize="11" Opacity="0.5"
                                                           FontFamily="Cascadia Code,Consolas,monospace"
                                                           IsVisible="{Binding !IsExpanded}"
                                                           TextWrapping="Wrap" />
                                                <SelectableTextBlock TextWrapping="Wrap"
                                                                     FontFamily="Cascadia Code,Consolas,monospace"
                                                                     FontSize="12"
                                                                     IsVisible="{Binding IsExpanded}"
                                                                     md:MarkdownRenderer.Markdown="{Binding DebouncedMarkdown}" />
                                            </StackPanel>

                                            <!-- Retrieval results: knowledge sources card -->
                                            <StackPanel Spacing="4" IsVisible="{Binding IsRetrieval}">
                                                <TextBlock Text="{DynamicResource ChatKnowledgeRetrieved}"
                                                           FontSize="11" Opacity="0.7"
                                                           FontFamily="Cascadia Code,Consolas,monospace" />
                                                <SelectableTextBlock TextWrapping="Wrap"
                                                                     FontFamily="Cascadia Code,Consolas,monospace"
                                                                     FontSize="11"
                                                                     md:MarkdownRenderer.Markdown="{Binding DebouncedMarkdown}" />
                                            </StackPanel>

                                            <!-- Regular message -->
                                            <StackPanel Spacing="4" IsVisible="{Binding IsRegular}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding RoleLabel}"
                                                               FontSize="11" Opacity="0.5"
                                                               VerticalAlignment="Center" />
                                                    <!-- Copy button -->
                                                    <Button Content="{DynamicResource ChatCopy}"
                                                            Command="{Binding CopyContentCommand}"
                                                            FontSize="10" Padding="6,2"
                                                            Background="Transparent" BorderThickness="0"
                                                            Opacity="0.5" />
                                                    <!-- Edit button (user messages only) -->
                                                    <Button Content="{DynamicResource ChatEdit}"
                                                            Command="{Binding StartEditCommand}"
                                                            FontSize="10" Padding="6,2"
                                                            Background="Transparent" BorderThickness="0"
                                                            Opacity="0.5"
                                                            IsVisible="{Binding IsUser}" />
                                                </StackPanel>

                                                <!-- Edit mode (user messages) -->
                                                <StackPanel Spacing="4" IsVisible="{Binding IsEditing}">
                                                    <TextBox Text="{Binding EditText}"
                                                             AcceptsReturn="True" MinHeight="60" FontSize="13" />
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Button Content="{DynamicResource ChatResend}" Padding="8,2" FontSize="12"
                                                                Command="{Binding $parent[ListBox].DataContext.Chat.ActiveTab.ResendCommand}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Content="{DynamicResource SettingsCancel}" Padding="8,2" FontSize="12"
                                                                Command="{Binding CancelEditCommand}" />
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Normal display -->
                                                <SelectableTextBlock TextWrapping="Wrap"
                                                                     FontFamily="Cascadia Code,Consolas,monospace"
                                                                     FontSize="13"
                                                                     IsVisible="{Binding !IsEditing}"
                                                                     md:MarkdownRenderer.Markdown="{Binding DebouncedMarkdown}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>

                    <!-- Search panel (toggle with Ctrl+F) -->
                    <Border DockPanel.Dock="Bottom" Padding="8,4" Margin="0,4,0,0"
                            IsVisible="{Binding IsSearchVisible}"
                            Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="0,1,0,0">
                        <StackPanel Spacing="4">
                            <TextBox Text="{Binding SearchQuery}" Watermark="Search messages..." />
                            <ItemsControl ItemsSource="{Binding SearchResults}" MaxHeight="200">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,2" Spacing="2">
                                            <TextBlock Text="{Binding Item1}" FontSize="11" Opacity="0.6" FontWeight="Bold" />
                                            <TextBlock Text="{Binding Item2.Content}" FontSize="11" Opacity="0.8"
                                                       TextWrapping="Wrap" MaxLines="2" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border DockPanel.Dock="Bottom" Padding="8,4" Margin="0,4,0,0"
                            IsVisible="{Binding Chat.ActiveTab, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <StackPanel Spacing="4">
                            <!-- Snippet search + dropdown -->
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBox x:Name="SnippetSearchBox"
                                         Watermark="Search snippets..."
                                         MinWidth="120"
                                         FontSize="11"
                                         TextChanged="OnSnippetSearchChanged" />
                                <ComboBox x:Name="SnippetComboBox"
                                          PlaceholderText="{DynamicResource ChatInsertSnippet}"
                                          MinWidth="200"
                                          IsEnabled="{Binding !Chat.ActiveTab.IsGenerating}"
                                          SelectionChanged="OnSnippetSelected">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="services:LuaSnippet">
                                            <StackPanel Spacing="2">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{Binding Category}" FontSize="9"
                                                               Foreground="{DynamicResource IsaacSyntaxKeywordBrush}"
                                                               Opacity="0.7" />
                                                    <TextBlock Text="{Binding Name}" FontSize="12" />
                                                    <TextBlock Text="★" FontSize="10" Opacity="0.5"
                                                               IsVisible="{Binding IsCustom}" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" FontSize="10" Opacity="0.5" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button x:Name="SnippetManageBtn"
                                        Content="⚙"
                                        FontSize="14" Padding="6,2"
                                        ToolTip.Tip="Manage custom snippets"
                                        Click="OnSnippetManage" />
                            </StackPanel>
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBox x:Name="ChatInputBox" Grid.Column="0"
                                         Text="{Binding Chat.ActiveTab.InputText}"
                                         Watermark="{DynamicResource ChatInputWatermark}"
                                         AcceptsReturn="True"
                                         MinHeight="40"
                                         IsEnabled="{Binding !Chat.ActiveTab.IsGenerating}"
                                         KeyDown="OnInputKeyDown" />
                                <Button Grid.Column="1"
                                        Content="{DynamicResource ChatSend}"
                                        Command="{Binding Chat.ActiveTab.SendCommand}"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Stretch"
                                        IsEnabled="{Binding !Chat.ActiveTab.IsGenerating}" />
                                <Button Grid.Column="2"
                                        Content="{DynamicResource ChatCancel}"
                                        Command="{Binding Chat.ActiveTab.CancelCommand}"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Stretch"
                                        IsVisible="{Binding Chat.ActiveTab.IsGenerating}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource PanelQuickReference}"
                               FontWeight="Bold" Margin="10,8" />
                    <ScrollViewer>
                        <StackPanel Spacing="4" Margin="10,0">
                            <TextBlock Text="{DynamicResource QuickRefCallbacks}" FontWeight="SemiBold" Margin="0,8,0,4" />
                            <ItemsControl ItemsSource="{Binding QuickReference.Callbacks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" Opacity="0.7" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="{DynamicResource QuickRefClasses}" FontWeight="SemiBold" Margin="0,12,0,4" />
                            <ItemsControl ItemsSource="{Binding QuickReference.Classes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" Opacity="0.7" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="{DynamicResource QuickRefModStructure}" FontWeight="SemiBold" Margin="0,12,0,4" />
                            <ItemsControl ItemsSource="{Binding QuickReference.ModStructure}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" Opacity="0.7" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Log Monitor Panel (collapsible) -->
        <Expander Grid.Row="2" Header="{DynamicResource LogMonitorHeader}"
                   Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                   Padding="10,2"
                   IsExpanded="False">
            <Grid RowDefinitions="Auto,*" Height="180">
                <!-- Controls -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
                    <Button Content="{DynamicResource LogMonitorStart}" Click="OnLogMonitorStart" Padding="10,2" FontSize="11" />
                    <Button Content="{DynamicResource LogMonitorStop}" Click="OnLogMonitorStop" Padding="10,2" FontSize="11"
                            IsEnabled="{Binding LogMonitor.IsMonitoring}" />
                    <Button Content="{DynamicResource LogMonitorClear}" Click="OnLogMonitorClear" Padding="10,2" FontSize="11" />
                    <Separator Margin="4,0" />
                    <CheckBox Content="{DynamicResource LogMonitorErrors}" IsChecked="{Binding LogMonitor.ShowErrors}" FontSize="11" />
                    <CheckBox Content="{DynamicResource LogMonitorWarnings}" IsChecked="{Binding LogMonitor.ShowWarnings}" FontSize="11" />
                    <CheckBox Content="{DynamicResource LogMonitorInfo}" IsChecked="{Binding LogMonitor.ShowInfo}" FontSize="11" />
                    <TextBlock Text="{Binding LogMonitor.StatusText}" FontSize="11" Opacity="0.6"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>

                <!-- Log entries -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding LogMonitor.Entries}"
                         Background="Transparent"
                         BorderThickness="0"
                         FontFamily="Cascadia Code,Consolas,monospace"
                         FontSize="11">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="services:LogEntry">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding LevelLabel}"
                                           Foreground="{Binding Level, Converter={x:Static services:LogLevelToBrushConverter.Instance}}"
                                           FontWeight="Bold" Width="30" />
                                <TextBlock Text="{Binding Line}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Expander>

        <Border Grid.Row="3" Background="{DynamicResource SystemControlBackgroundAltMediumBrush}" Padding="10,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" FontSize="11" Opacity="0.6"
                           FontFamily="Cascadia Code,Consolas,monospace"
                           IsVisible="{Binding Chat.ActiveTab, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="↑{0} ↓{1} tokens">
                            <Binding Path="Chat.ActiveTab.TotalInputTokens" />
                            <Binding Path="Chat.ActiveTab.TotalOutputTokens" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <TextBlock Text="{Binding StatusText}" FontSize="12" Opacity="0.7" />
            </DockPanel>
        </Border>

        <!-- Toast notification overlay -->
        <Panel Grid.Row="0" Grid.RowSpan="4" IsHitTestVisible="False"
               HorizontalAlignment="Right" VerticalAlignment="Bottom"
               Margin="0,0,16,40">
            <ItemsControl ItemsSource="{Binding Toasts.ActiveToasts}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" Spacing="6" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ToastNotification">
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                CornerRadius="6"
                                Padding="12,8"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                BorderThickness="1"
                                BoxShadow="0 2 8 0 #40000000">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Icon}" FontSize="16"
                                           Foreground="{Binding Severity, Converter={x:Static conv:ToastSeverityToBrushConverter.Instance}}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Message}" FontSize="13"
                                           VerticalAlignment="Center" MaxWidth="400" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Panel>
    </Grid>
</Window>
