<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IsaacAgent.App.ViewModels"
        xmlns:services="using:IsaacAgent.App.Services"
        xmlns:conv="using:IsaacAgent.App.Converters"
        xmlns:md="using:IsaacAgent.App.Markdown"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        x:Class="IsaacAgent.App.Views.MainWindow"
        Title="{DynamicResource AppTitle}"
        Width="1200" Height="800"
        WindowState="Maximized"
        x:DataType="vm:MainViewModel">

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <Menu Grid.Row="0" Background="{DynamicResource IsaacSurfaceBrush}">
            <MenuItem Header="{DynamicResource MenuFile}">
                <MenuItem Header="{DynamicResource MenuFileNewProject}" Command="{Binding NewProjectAsyncCommand}" />
                <MenuItem Header="{DynamicResource MenuFileNewFromTemplate}" Click="OnTemplateGallery" InputGesture="Ctrl+Shift+T" />
                <MenuItem Header="{DynamicResource MenuFileOpenProject}" Command="{Binding OpenProjectAsyncCommand}" />
                <Separator />
                <MenuItem Header="{DynamicResource MenuFileSettings}" Click="OnSettings" />
                <Separator />
                <MenuItem Header="{DynamicResource MenuFileExit}" Click="OnExit" />
            </MenuItem>
            <MenuItem Header="{DynamicResource MenuChat}">
                <MenuItem Header="{DynamicResource MenuChatClear}" Command="{Binding ClearChatCommand}" />
                <Separator />
                <MenuItem Header="{DynamicResource MenuChatExportMarkdown}" Command="{Binding ExportChatMarkdownCommand}" />
                <MenuItem Header="{DynamicResource MenuChatExportJson}" Command="{Binding ExportChatJsonCommand}" />
            </MenuItem>
            <MenuItem Header="{DynamicResource MenuView}">
                <MenuItem Header="{DynamicResource MenuViewDiffViewer}" Click="OnDiffViewer" InputGesture="Ctrl+Shift+D" />
            </MenuItem>
            <MenuItem Header="{DynamicResource MenuHelp}">
                <MenuItem Header="{DynamicResource MenuHelpCommandPalette}" Click="OnCommandPalette" InputGesture="Ctrl+Shift+P" />
                <Separator />
                <MenuItem Header="{DynamicResource MenuHelpAbout}" Click="OnAbout" />
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1" ColumnDefinitions="260,*,320">

            <!-- ===== Left sidebar: Project files ===== -->
            <Border Grid.Column="0" Classes="panel">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource PanelProjectFiles}"
                               Classes="header" Margin="12,10,12,4" />
                    <TextBlock DockPanel.Dock="Top" Text="{Binding Project.ProjectName}"
                               Classes="caption" Margin="12,0,12,8"
                               IsVisible="{Binding Project.HasProject}" />

                    <!-- File search box (only when project loaded) -->
                    <TextBox DockPanel.Dock="Top"
                             Text="{Binding Project.FileSearchText}"
                             Watermark="{DynamicResource FileSearchWatermark}"
                             Classes="search"
                             Margin="12,0,12,8"
                             IsVisible="{Binding Project.HasProject}">
                        <TextBox.InnerLeftContent>
                            <i:Icon Value="mdi-magnify" FontSize="14" Opacity="0.5" Margin="8,0,0,0" />
                        </TextBox.InnerLeftContent>
                    </TextBox>

                    <Border DockPanel.Dock="Bottom"
                            IsVisible="{Binding Project.HasFilePreview}"
                            BorderBrush="{DynamicResource IsaacBorderSubtleBrush}"
                            BorderThickness="0,1,0,0"
                            MaxHeight="300">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="{Binding Project.FilePreviewName}"
                                       Classes="mono caption"
                                       Margin="12,8,12,4" />
                            <ScrollViewer>
                                <TextBox Text="{Binding Project.FilePreviewContent}"
                                         IsReadOnly="True"
                                         Classes="mono"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         Margin="8,0,8,8" />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- File search results (shown when searching) -->
                    <ListBox x:Name="FileSearchResults"
                             ItemsSource="{Binding Project.FilteredFiles}"
                             Classes="isaac"
                             Margin="4,0"
                             DoubleTapped="OnFileDoubleTapped"
                             IsVisible="{Binding Project.HasFileSearch}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:FileTreeItem">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="Lua" Foreground="{DynamicResource IsaacLuaTagBrush}"
                                               IsVisible="{Binding IsLua}"
                                               FontSize="10" VerticalAlignment="Center" />
                                    <TextBlock Text="XML" Foreground="{DynamicResource IsaacXmlTagBrush}"
                                               IsVisible="{Binding IsXml}"
                                               FontSize="10" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Path}" VerticalAlignment="Center" FontSize="12" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TreeView x:Name="FileTreeView"
                              ItemsSource="{Binding Project.Files}"
                              Classes="isaac"
                              Margin="4,0"
                              DoubleTapped="OnFileDoubleTapped"
                              IsVisible="{Binding !Project.HasFileSearch}">
                        <TreeView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{DynamicResource FileNewFile}"
                                          Command="{Binding Project.CreateNewFileCommand}"
                                          CommandParameter="{Binding $self}" />
                                <MenuItem Header="{DynamicResource FileNewFolder}"
                                          Command="{Binding Project.CreateNewFolderCommand}"
                                          CommandParameter="{Binding $self}" />
                                <Separator />
                                <MenuItem Header="{DynamicResource FileRename}"
                                          Command="{Binding Project.RenameFileCommand}"
                                          CommandParameter="{Binding $self}" />
                                <MenuItem Header="{DynamicResource FileDelete}"
                                          Command="{Binding Project.DeleteFileCommand}"
                                          CommandParameter="{Binding $self}" />
                                <Separator />
                                <MenuItem Header="{DynamicResource FileCopyPath}"
                                          Command="{Binding Project.CopyPathCommand}"
                                          CommandParameter="{Binding $self}" />
                                <MenuItem Header="{DynamicResource FileOpenInExplorer}"
                                          Command="{Binding Project.OpenInExplorerCommand}"
                                          CommandParameter="{Binding $self}" />
                                <MenuItem Header="{DynamicResource FileOpenExternal}"
                                          Command="{Binding Project.OpenInExternalEditorCommand}"
                                          CommandParameter="{Binding $self}" />
                            </ContextMenu>
                        </TreeView.ContextMenu>
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate x:DataType="vm:FileTreeItem"
                                              ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <i:Icon Value="mdi-folder" FontSize="14" Opacity="0.7"
                                                   IsVisible="{Binding IsDirectory}"
                                                   VerticalAlignment="Center" />
                                    <TextBlock Text="Lua" Foreground="{DynamicResource IsaacLuaTagBrush}"
                                               IsVisible="{Binding IsLua}"
                                               FontSize="10" VerticalAlignment="Center" />
                                    <TextBlock Text="XML" Foreground="{DynamicResource IsaacXmlTagBrush}"
                                               IsVisible="{Binding IsXml}"
                                               FontSize="10" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <!-- Empty state: no project loaded -->
                    <StackPanel IsVisible="{Binding !Project.HasProject}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="12" Margin="20">
                        <i:Icon Value="mdi-folder-open" FontSize="48" Opacity="0.3" HorizontalAlignment="Center" />
                        <TextBlock Text="No project loaded"
                                   HorizontalAlignment="Center"
                                   Classes="caption" FontSize="13" />
                        <TextBlock Text="Open a mod folder via File menu&#x0a;or drag a folder here to begin"
                                   HorizontalAlignment="Center"
                                   Classes="caption" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="200" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Padding="0">
                <DockPanel>
                    <!-- Tab bar -->
                    <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource IsaacBorderSubtleBrush}" BorderThickness="0,0,0,1" Padding="8,6,8,0">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Classes="icon"
                                    Command="{Binding Chat.AddTabCommand}"
                                    Margin="4,0,0,0">
                                <i:Icon Value="mdi-plus" FontSize="16" />
                            </Button>
                            <ItemsControl ItemsSource="{Binding Chat.Tabs}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ChatTabViewModel">
                                        <Panel>
                                            <!-- Active tab: highlighted with accent border -->
                                            <Border Padding="10,6" CornerRadius="6,6,0,0"
                                                    BorderBrush="{DynamicResource IsaacAccentBrush}" BorderThickness="0,0,0,2"
                                                    IsVisible="{Binding IsActive}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Button Classes="tab" Padding="0"
                                                            Command="{Binding $parent[ItemsControl].DataContext.Chat.SelectTabCommand}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" />
                                                    </Button>
                                                    <Button Classes="icon" Padding="2,0"
                                                            Command="{Binding $parent[ItemsControl].DataContext.Chat.CloseTabCommand}"
                                                            CommandParameter="{Binding}"
                                                            FontSize="12" Opacity="0.4"
                                                            IsVisible="{Binding $parent[ItemsControl].DataContext.Chat.CanCloseTabs}">
                                                        <i:Icon Value="mdi-close" FontSize="10" />
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                            <!-- Inactive tab: dimmed -->
                                            <Border Padding="10,6" CornerRadius="6,6,0,0"
                                                    Background="Transparent"
                                                    IsVisible="{Binding !IsActive}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Button Classes="tab" Padding="0"
                                                            Command="{Binding $parent[ItemsControl].DataContext.Chat.SelectTabCommand}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="{Binding Title}" FontSize="12" Opacity="0.5" />
                                                    </Button>
                                                    <Button Classes="icon" Padding="2,0"
                                                            Command="{Binding $parent[ItemsControl].DataContext.Chat.CloseTabCommand}"
                                                            CommandParameter="{Binding}"
                                                            FontSize="12" Opacity="0.3"
                                                            IsVisible="{Binding $parent[ItemsControl].DataContext.Chat.CanCloseTabs}">
                                                        <i:Icon Value="mdi-close" FontSize="10" />
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </Panel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DockPanel>
                    </Border>

                    <!-- Chat empty state: no active tab -->
                    <StackPanel DockPanel.Dock="Top" IsVisible="{Binding Chat.ActiveTab, Converter={x:Static ObjectConverters.IsNull}}"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Spacing="16" Margin="40">
                        <i:Icon Value="mdi-chat" FontSize="56" Opacity="0.3" HorizontalAlignment="Center" />
                        <TextBlock Text="Start a conversation"
                                   HorizontalAlignment="Center"
                                   FontSize="16" FontWeight="SemiBold" Opacity="0.7" />
                        <TextBlock Text="Type a message below to chat with the AI agent&#x0a;about your Binding of Isaac mod project"
                                   HorizontalAlignment="Center"
                                   Classes="caption" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="320" />
                    </StackPanel>

                    <!-- Chat content for active tab (virtualized for performance) -->
                    <ScrollViewer x:Name="ChatScrollViewer" DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto"
                                  IsVisible="{Binding Chat.ActiveTab, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <ListBox ItemsSource="{Binding Chat.ActiveTab.Messages}" Padding="12"
                                 Classes="isaac"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ChatMessageViewModel">
                                    <Border CornerRadius="8" Padding="14,10"
                                            Background="{Binding BackgroundBrush}"
                                            HorizontalAlignment="{Binding HorizontalAlign}"
                                            MaxWidth="640"
                                            BoxShadow="0 1 3 0 #20000000"
                                            Margin="0,3">
                                        <Border.Transitions>
                                            <Transitions>
                                                <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                                            </Transitions>
                                        </Border.Transitions>
                                        <Grid>
                                            <!-- Tool call/result: collapsible card -->
                                            <StackPanel Spacing="6" IsVisible="{Binding IsTool}">
                                                <Button Command="{Binding $parent[ListBox].DataContext.Chat.ActiveTab.ToggleExpandCommand}"
                                                        CommandParameter="{Binding}"
                                                        Classes="ghost"
                                                        HorizontalAlignment="Left"
                                                        Padding="6,2">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{Binding RoleLabel}"
                                                                   Classes="mono caption" />
                                                        <i:Icon Value="mdi-chevron-down" FontSize="10" Opacity="0.4"
                                                                   IsVisible="{Binding IsExpanded}" />
                                                        <i:Icon Value="mdi-chevron-right" FontSize="10" Opacity="0.4"
                                                                   IsVisible="{Binding !IsExpanded}" />
                                                    </StackPanel>
                                                </Button>
                                                <TextBlock Text="{Binding ToolArgsPreview}"
                                                           Classes="mono caption"
                                                           IsVisible="{Binding !IsExpanded}"
                                                           TextWrapping="Wrap" />
                                                <SelectableTextBlock TextWrapping="Wrap"
                                                                     Classes="mono"
                                                                     IsVisible="{Binding IsExpanded}"
                                                                     md:MarkdownRenderer.Markdown="{Binding DebouncedMarkdown}" />
                                            </StackPanel>

                                            <!-- Retrieval results: knowledge sources card -->
                                            <StackPanel Spacing="6" IsVisible="{Binding IsRetrieval}">
                                                <TextBlock Text="{DynamicResource ChatKnowledgeRetrieved}"
                                                           Classes="mono caption" />
                                                <SelectableTextBlock TextWrapping="Wrap"
                                                                     Classes="mono"
                                                                     FontSize="11"
                                                                     md:MarkdownRenderer.Markdown="{Binding DebouncedMarkdown}" />
                                            </StackPanel>

                                            <!-- Regular message -->
                                            <StackPanel Spacing="6" IsVisible="{Binding IsRegular}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{Binding RoleLabel}"
                                                               Classes="caption"
                                                               VerticalAlignment="Center" />
                                                    <!-- Copy button -->
                                                    <Button Content="{DynamicResource ChatCopy}"
                                                            Command="{Binding CopyContentCommand}"
                                                            Classes="ghost"
                                                            FontSize="10" Padding="6,2"
                                                            Opacity="0.4" />
                                                    <!-- Edit button (user messages only) -->
                                                    <Button Content="{DynamicResource ChatEdit}"
                                                            Command="{Binding StartEditCommand}"
                                                            Classes="ghost"
                                                            FontSize="10" Padding="6,2"
                                                            Opacity="0.4"
                                                            IsVisible="{Binding IsUser}" />
                                                </StackPanel>

                                                <!-- Edit mode (user messages) -->
                                                <StackPanel Spacing="6" IsVisible="{Binding IsEditing}">
                                                    <TextBox Text="{Binding EditText}"
                                                             AcceptsReturn="True" MinHeight="60"
                                                             Classes="isaac" FontSize="13" />
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Button Content="{DynamicResource ChatResend}" Classes="primary" FontSize="12"
                                                                Command="{Binding $parent[ListBox].DataContext.Chat.ActiveTab.ResendCommand}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Content="{DynamicResource SettingsCancel}" Classes="ghost" FontSize="12"
                                                                Command="{Binding CancelEditCommand}" />
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Normal display -->
                                                <SelectableTextBlock TextWrapping="Wrap"
                                                                     Classes="mono"
                                                                     FontSize="13"
                                                                     IsVisible="{Binding !IsEditing}"
                                                                     md:MarkdownRenderer.Markdown="{Binding DebouncedMarkdown}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>

                    <!-- Search panel (toggle with Ctrl+F) -->
                    <Border DockPanel.Dock="Bottom" Padding="12,8" Margin="8,4,8,0"
                            IsVisible="{Binding IsSearchVisible}"
                            Background="{DynamicResource IsaacSurfaceVariantBrush}"
                            BorderBrush="{DynamicResource IsaacBorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel Spacing="6">
                            <TextBox Text="{Binding SearchQuery}" Watermark="Search messages..." Classes="isaac" />
                            <ItemsControl ItemsSource="{Binding SearchResults}" MaxHeight="200">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,3" Spacing="2">
                                            <TextBlock Text="{Binding Item1}" FontSize="11" Opacity="0.5" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Item2.Content}" FontSize="11" Opacity="0.8"
                                                       TextWrapping="Wrap" MaxLines="2" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border DockPanel.Dock="Bottom" Padding="12,8" Margin="8,0,8,8"
                            Background="{DynamicResource IsaacSurfaceVariantBrush}"
                            BorderBrush="{DynamicResource IsaacBorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            IsVisible="{Binding Chat.ActiveTab, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <StackPanel Spacing="6">
                            <!-- Snippet search + dropdown -->
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBox x:Name="SnippetSearchBox"
                                         Watermark="Search snippets..."
                                         Classes="isaac"
                                         MinWidth="120"
                                         TextChanged="OnSnippetSearchChanged" />
                                <ComboBox x:Name="SnippetComboBox"
                                          PlaceholderText="{DynamicResource ChatInsertSnippet}"
                                          MinWidth="200"
                                          IsEnabled="{Binding !Chat.ActiveTab.IsGenerating}"
                                          SelectionChanged="OnSnippetSelected">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="services:LuaSnippet">
                                            <StackPanel Spacing="2">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{Binding Category}" FontSize="9"
                                                               Foreground="{DynamicResource IsaacSyntaxKeywordBrush}"
                                                               Opacity="0.7" />
                                                    <TextBlock Text="{Binding Name}" FontSize="12" />
                                                    <i:Icon Value="mdi-star" FontSize="10" Opacity="0.5"
                                                               IsVisible="{Binding IsCustom}" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" FontSize="10" Opacity="0.5" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button x:Name="SnippetManageBtn"
                                        Classes="icon"
                                        ToolTip.Tip="Manage custom snippets"
                                        Click="OnSnippetManage">
                                    <i:Icon Value="mdi-cog" FontSize="16" />
                                </Button>
                            </StackPanel>
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBox x:Name="ChatInputBox" Grid.Column="0"
                                         Text="{Binding Chat.ActiveTab.InputText}"
                                         Watermark="{DynamicResource ChatInputWatermark}"
                                         AcceptsReturn="True"
                                         MinHeight="44"
                                         Classes="isaac"
                                         IsEnabled="{Binding !Chat.ActiveTab.IsGenerating}"
                                         KeyDown="OnInputKeyDown" />
                                <Button Grid.Column="1"
                                        Content="{DynamicResource ChatSend}"
                                        Classes="primary"
                                        Command="{Binding Chat.ActiveTab.SendCommand}"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Stretch"
                                        IsEnabled="{Binding !Chat.ActiveTab.IsGenerating}" />
                                <Button Grid.Column="2"
                                        Content="{DynamicResource ChatCancel}"
                                        Command="{Binding Chat.ActiveTab.CancelCommand}"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Stretch"
                                        IsVisible="{Binding Chat.ActiveTab.IsGenerating}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- ===== Right sidebar: Quick reference ===== -->
            <Border Grid.Column="2" Classes="panel" BorderThickness="1,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource PanelQuickReference}"
                               Classes="header" Margin="12,10,12,8" />
                    <ScrollViewer>
                        <StackPanel Spacing="8" Margin="12,0,12,12">
                            <!-- Callbacks section -->
                            <Border Classes="card" Padding="10,8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{DynamicResource QuickRefCallbacks}" Classes="header" />
                                    <ItemsControl ItemsSource="{Binding QuickReference.Callbacks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Classes="mono caption" Text="{Binding}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Classes section -->
                            <Border Classes="card" Padding="10,8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{DynamicResource QuickRefClasses}" Classes="header" />
                                    <ItemsControl ItemsSource="{Binding QuickReference.Classes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Classes="mono caption" Text="{Binding}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Mod structure section -->
                            <Border Classes="card" Padding="10,8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{DynamicResource QuickRefModStructure}" Classes="header" />
                                    <ItemsControl ItemsSource="{Binding QuickReference.ModStructure}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Classes="mono caption" Text="{Binding}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Log Monitor Panel (collapsible) -->
        <Expander Grid.Row="2" Header="{DynamicResource LogMonitorHeader}"
                   Classes="isaac"
                   Background="{DynamicResource IsaacSurfaceBrush}"
                   Padding="12,6"
                   IsExpanded="False">
            <Grid RowDefinitions="Auto,*" Height="180">
                <!-- Controls -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,6,0,6">
                    <Button Content="{DynamicResource LogMonitorStart}" Click="OnLogMonitorStart" Classes="ghost" FontSize="11" />
                    <Button Content="{DynamicResource LogMonitorStop}" Click="OnLogMonitorStop" Classes="ghost" FontSize="11"
                            IsEnabled="{Binding LogMonitor.IsMonitoring}" />
                    <Button Content="{DynamicResource LogMonitorClear}" Click="OnLogMonitorClear" Classes="ghost" FontSize="11" />
                    <Separator Classes="isaac" Margin="4,0" />
                    <CheckBox Content="{DynamicResource LogMonitorErrors}" IsChecked="{Binding LogMonitor.ShowErrors}" FontSize="11" />
                    <CheckBox Content="{DynamicResource LogMonitorWarnings}" IsChecked="{Binding LogMonitor.ShowWarnings}" FontSize="11" />
                    <CheckBox Content="{DynamicResource LogMonitorInfo}" IsChecked="{Binding LogMonitor.ShowInfo}" FontSize="11" />
                    <TextBlock Text="{Binding LogMonitor.StatusText}" Classes="caption"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>

                <!-- Log entries -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding LogMonitor.Entries}"
                         Classes="isaac"
                         FontFamily="Cascadia Code,Consolas,monospace"
                         FontSize="11">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="services:LogEntry">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding LevelLabel}"
                                           Foreground="{Binding Level, Converter={x:Static services:LogLevelToBrushConverter.Instance}}"
                                           FontWeight="Bold" Width="30" />
                                <TextBlock Text="{Binding Line}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Expander>

        <Border Grid.Row="3" Background="{DynamicResource IsaacSurfaceBrush}" Padding="12,6"
                BorderBrush="{DynamicResource IsaacBorderSubtleBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Classes="caption mono"
                           IsVisible="{Binding Chat.ActiveTab, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="↑{0} ↓{1} tokens">
                            <Binding Path="Chat.ActiveTab.TotalInputTokens" />
                            <Binding Path="Chat.ActiveTab.TotalOutputTokens" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <TextBlock Text="{Binding StatusText}" FontSize="12" Opacity="0.7" />
            </DockPanel>
        </Border>

        <!-- Toast notification overlay -->
        <Panel Grid.Row="0" Grid.RowSpan="4" IsHitTestVisible="False"
               HorizontalAlignment="Right" VerticalAlignment="Bottom"
               Margin="0,0,16,40">
            <ItemsControl ItemsSource="{Binding Toasts.ActiveToasts}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" Spacing="8" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ToastNotification">
                        <Border Classes="toast"
                                Background="{DynamicResource IsaacSurfaceVariantBrush}"
                                CornerRadius="8"
                                Padding="14,10"
                                BorderBrush="{DynamicResource IsaacBorderSubtleBrush}"
                                BorderThickness="1"
                                BoxShadow="0 4 12 0 #50000000">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{Binding Icon}" FontSize="18"
                                           Foreground="{Binding Severity, Converter={x:Static conv:ToastSeverityToBrushConverter.Instance}}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Message}" FontSize="13"
                                           VerticalAlignment="Center" MaxWidth="400" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Panel>
    </Grid>
</Window>


