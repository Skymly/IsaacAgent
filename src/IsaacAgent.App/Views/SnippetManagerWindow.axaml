<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="using:IsaacAgent.App.Services"
        x:Class="IsaacAgent.App.Views.SnippetManagerWindow"
        Title="Snippet Manager"
        Width="600" Height="500"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource SystemControlBackgroundAltMediumBrush}">

    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" Text="Snippet Manager"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />

        <!-- Add/Edit form -->
        <Border DockPanel.Dock="Top" Padding="12" Margin="0,0,0,12"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1" CornerRadius="6">
            <StackPanel Spacing="6">
                <TextBlock Text="Add Custom Snippet" FontWeight="Bold" FontSize="13" />
                <Grid ColumnDefinitions="*,*,*">
                    <TextBox x:Name="NameBox" Grid.Column="0" Watermark="Name" Margin="0,0,4,0" />
                    <TextBox x:Name="CategoryBox" Grid.Column="1" Watermark="Category" Margin="4,0,4,0" />
                    <TextBox x:Name="DescBox" Grid.Column="2" Watermark="Description" Margin="4,0,0,0" />
                </Grid>
                <TextBox x:Name="CodeBox" Watermark="Lua code..."
                         AcceptsReturn="True" MinHeight="60"
                         FontFamily="Cascadia Code,Consolas,monospace" FontSize="12" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="AddBtn" Content="Add" Click="OnAddSnippet" Padding="16,4" />
                    <Button x:Name="DeleteBtn" Content="Delete Selected" Click="OnDeleteSnippet"
                            Padding="16,4" IsEnabled="False" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Snippet list grouped by category -->
        <ScrollViewer>
            <ItemsControl x:Name="SnippetList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="services:SnippetCategoryGroup">
                        <StackPanel Margin="0,4" Spacing="2">
                            <TextBlock Text="{Binding Category}" FontWeight="Bold" FontSize="13"
                                       Foreground="{DynamicResource IsaacSyntaxKeywordBrush}" />
                            <ItemsControl ItemsSource="{Binding Snippets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="services:LuaSnippet">
                                        <Border Padding="8,4" Margin="0,2"
                                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                                CornerRadius="4"
                                                PointerPressed="OnSnippetPointerPressed">
                                            <StackPanel Spacing="2">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Bold" />
                                                    <TextBlock Text="★" FontSize="10" Opacity="0.5"
                                                               IsVisible="{Binding IsCustom}" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" FontSize="10" Opacity="0.6" />
                                                <TextBlock Text="{Binding Code}" FontSize="10"
                                                           FontFamily="Cascadia Code,Consolas,monospace"
                                                           Opacity="0.7" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
