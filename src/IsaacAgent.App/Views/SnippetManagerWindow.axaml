<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="using:IsaacAgent.App.Services"
        x:Class="IsaacAgent.App.Views.SnippetManagerWindow"
        Title="Snippet Manager"
        Width="620" Height="520"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource IsaacSurfaceBrush}">

    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Text="Snippet Manager"
                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" />

        <!-- Add/Edit form -->
        <Border DockPanel.Dock="Top" Classes="card" Padding="14" Margin="0,0,0,16">
            <StackPanel Spacing="10">
                <TextBlock Text="Add Custom Snippet" Classes="header" FontSize="13" />
                <Separator Classes="isaac" Margin="0,2" />
                <Grid ColumnDefinitions="*,*,*">
                    <TextBox x:Name="NameBox" Grid.Column="0" Watermark="Name" Margin="0,0,4,0" Classes="isaac" />
                    <TextBox x:Name="CategoryBox" Grid.Column="1" Watermark="Category" Margin="4,0,4,0" Classes="isaac" />
                    <TextBox x:Name="DescBox" Grid.Column="2" Watermark="Description" Margin="4,0,0,0" Classes="isaac" />
                </Grid>
                <TextBox x:Name="CodeBox" Watermark="Lua code..."
                         AcceptsReturn="True" MinHeight="60"
                         Classes="isaac mono" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="AddBtn" Content="Add" Click="OnAddSnippet" Classes="primary" />
                    <Button x:Name="DeleteBtn" Content="Delete Selected" Click="OnDeleteSnippet"
                            Classes="ghost" IsEnabled="False" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Snippet list grouped by category -->
        <ScrollViewer>
            <ItemsControl x:Name="SnippetList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="services:SnippetCategoryGroup">
                        <StackPanel Margin="0,6" Spacing="4">
                            <TextBlock Text="{Binding Category}" Classes="header" FontSize="13"
                                       Foreground="{DynamicResource IsaacSyntaxKeywordBrush}" />
                            <ItemsControl ItemsSource="{Binding Snippets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="services:LuaSnippet">
                                        <Border Padding="10,6" Margin="0,3"
                                                Background="{DynamicResource IsaacSurfaceVariantBrush}"
                                                BorderBrush="{DynamicResource IsaacBorderSubtleBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                PointerPressed="OnSnippetPointerPressed">
                                            <StackPanel Spacing="3">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" />
                                                    <TextBlock Text="★" FontSize="10" Opacity="0.5"
                                                               IsVisible="{Binding IsCustom}" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" Classes="caption" />
                                                <TextBlock Text="{Binding Code}" Classes="mono caption"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
