<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IsaacAgent.App.ViewModels"
        xmlns:core="using:IsaacAgent.Core.Models"
        x:Class="IsaacAgent.App.Views.TemplateGalleryWindow"
        Title="{DynamicResource TemplateGalleryTitle}"
        Width="800" Height="600"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        x:DataType="vm:TemplateGalleryViewModel">

    <Grid ColumnDefinitions="280,*" Margin="12">

        <!-- Template list -->
        <DockPanel Grid.Column="0" Margin="0,0,12,0">
            <TextBlock DockPanel.Dock="Top" Text="{DynamicResource TemplateGalleryTemplates}"
                       FontWeight="Bold" FontSize="14" Margin="0,0,0,8" />
            <ListBox ItemsSource="{Binding Templates}"
                     SelectedItem="{Binding SelectedTemplate}"
                     Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="core:ModTemplate">
                        <StackPanel Spacing="2" Margin="4,4">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="{Binding Category}" FontSize="10" Opacity="0.5" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Template detail + form -->
        <DockPanel Grid.Column="1" IsVisible="{Binding SelectedTemplate, Converter={x:Static ObjectConverters.IsNotNull}}">

            <!-- Form fields -->
            <StackPanel DockPanel.Dock="Bottom" Spacing="8" Margin="0,12,0,0">
                <TextBox Text="{Binding ModName}"
                         Watermark="{DynamicResource TemplateGalleryModNameWatermark}"
                         FontSize="13" />
                <TextBox Text="{Binding ModDescription}"
                         Watermark="{DynamicResource TemplateGalleryModDescWatermark}"
                         FontSize="13" />
                <TextBox Text="{Binding ModAuthor}"
                         Watermark="{DynamicResource TemplateGalleryAuthorWatermark}"
                         FontSize="13" />
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                    <Button Content="{DynamicResource TemplateGalleryScaffold}"
                            Command="{Binding ScaffoldCommand}"
                            Padding="16,6"
                            FontSize="13" />
                    <Button Content="{DynamicResource TemplateGalleryCancel}"
                            Click="OnCancel"
                            Padding="16,6"
                            FontSize="13" />
                </StackPanel>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="11" Opacity="0.7"
                           IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>

            <!-- Preview -->
            <ScrollViewer>
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding SelectedTemplate.Description}"
                               FontSize="13" TextWrapping="Wrap" Opacity="0.8" />
                    <TextBlock Text="{DynamicResource TemplateGalleryPreview}"
                               FontWeight="SemiBold" FontSize="12"
                               Margin="0,8,0,4" />
                    <Border Background="{DynamicResource IsaacCodeBlockBgBrush}" CornerRadius="4" Padding="12">
                        <SelectableTextBlock Text="{Binding SelectedTemplate.Preview}"
                                             FontFamily="Cascadia Code,Consolas,monospace"
                                             FontSize="12"
                                             TextWrapping="Wrap"
                                             Foreground="{DynamicResource IsaacCodeFgBrush}" />
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- Empty state -->
        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="8"
                    IsVisible="{Binding SelectedTemplate, Converter={x:Static ObjectConverters.IsNull}}">
            <TextBlock Text="{DynamicResource TemplateGallerySelectPrompt}"
                       FontSize="14" Opacity="0.4" />
        </StackPanel>
    </Grid>
</Window>
