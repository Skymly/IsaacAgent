<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IsaacAgent.App.ViewModels"
        x:Class="IsaacAgent.App.Views.CommandPaletteWindow"
        Title="{DynamicResource CommandPaletteTitle}"
        Width="520" Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="None"
        x:DataType="vm:CommandPaletteViewModel">

    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="1" CornerRadius="6"
            Background="{DynamicResource SystemControlBackgroundAltMediumBrush}">
        <Grid RowDefinitions="Auto,*,Auto">
            <!-- Search box -->
            <TextBox Grid.Row="0"
                     x:Name="SearchBox"
                     Text="{Binding SearchText}"
                     Watermark="{DynamicResource CommandPaletteWatermark}"
                     BorderThickness="0"
                     Padding="14,10"
                     FontSize="15"
                     Background="Transparent"
                     KeyDown="OnSearchKeyDown" />

            <Separator Grid.Row="0" VerticalAlignment="Bottom" />

            <!-- Command list -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding FilteredCommands}"
                     SelectedItem="{Binding SelectedCommand}"
                     Background="Transparent"
                     BorderThickness="0"
                     DoubleTapped="OnCommandDoubleTapped">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:CommandItem">
                        <Grid ColumnDefinitions="*,Auto" Margin="4,2">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{Binding Title}" FontSize="13" />
                                <TextBlock Text="{Binding Category}" FontSize="10" Opacity="0.5" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DisplayShortcut}"
                                       FontSize="11" Opacity="0.4"
                                       VerticalAlignment="Center"
                                       FontFamily="Cascadia Code,Consolas,monospace" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Footer hint -->
            <Border Grid.Row="2" Padding="14,6"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock FontSize="11" Opacity="0.5">
                        <Run Text="↑↓ " /><Run Text="{DynamicResource CommandPaletteNavigate}" />
                    </TextBlock>
                    <TextBlock FontSize="11" Opacity="0.5">
                        <Run Text="Enter " /><Run Text="{DynamicResource CommandPaletteExecute}" />
                    </TextBlock>
                    <TextBlock FontSize="11" Opacity="0.5">
                        <Run Text="Esc " /><Run Text="{DynamicResource CommandPaletteClose}" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
