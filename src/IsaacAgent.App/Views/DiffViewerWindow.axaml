<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IsaacAgent.App.ViewModels"
        xmlns:services="using:IsaacAgent.App.Services"
        x:Class="IsaacAgent.App.Views.DiffViewerWindow"
        Title="Diff Viewer"
        Width="900" Height="600"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        x:DataType="vm:DiffViewerViewModel">

    <Grid RowDefinitions="Auto,*,Auto" Margin="12">

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="12,4" />
                <TextBlock Text="{Binding DiffService.StatusText}"
                           VerticalAlignment="Center" Opacity="0.7" FontSize="12" />
            </StackPanel>
            <!-- File selector -->
            <ComboBox ItemsSource="{Binding DiffService.Files}"
                      SelectedItem="{Binding SelectedFile}"
                      PlaceholderText="Select a file..."
                      MinWidth="400">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="services:DiffFile">
                        <TextBlock Text="{Binding Summary}" FontFamily="Cascadia Code,Consolas,monospace" FontSize="12" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <!-- Diff content -->
        <Border Grid.Row="1" Background="{DynamicResource IsaacCodeBlockBgBrush}" CornerRadius="4" Padding="0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding SelectedFile.Lines}" Padding="4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="services:DiffLine">
                            <Grid ColumnDefinitions="40,40,*">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding OldLineNumber}"
                                           Foreground="{DynamicResource IsaacDiffLineNumberBrush}" FontSize="11"
                                           FontFamily="Cascadia Code,Consolas,monospace"
                                           Padding="4,0" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding NewLineNumber}"
                                           Foreground="{DynamicResource IsaacDiffLineNumberBrush}" FontSize="11"
                                           FontFamily="Cascadia Code,Consolas,monospace"
                                           Padding="4,0" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Content}"
                                           FontFamily="Cascadia Code,Consolas,monospace"
                                           FontSize="12"
                                           TextWrapping="NoWrap"
                                           Padding="4,0"
                                           Foreground="{Binding Type, Converter={x:Static services:DiffLineTypeToBrushConverter.Instance}}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="16" Margin="0,8,0,0">
            <TextBlock FontSize="11" Opacity="0.5">
                <Run Foreground="{DynamicResource IsaacDiffAddedBrush}" Text="+ added" />
                <Run Text="  " />
                <Run Foreground="{DynamicResource IsaacDiffRemovedBrush}" Text="- removed" />
                <Run Text="  " />
                <Run Foreground="{DynamicResource IsaacDiffLineNumberBrush}" Text="  context" />
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
